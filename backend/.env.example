# ── Server ──────────────────────────────────────────
PORT=5002
NODE_ENV=development   # change to 'production' for deployment

# ── MongoDB ──────────────────────────────────────────
MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/dbname?retryWrites=true&w=majority

# ── JWT ──────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_64_CHAR_STRING
JWT_ACCESS_EXPIRATION=1h
JWT_REFRESH_EXPIRATION=7d

# ── Chapa Payment ────────────────────────────────────
CHAPA_SECRET_KEY=CHASECK_TEST-your_key_here
CHAPA_PUBLIC_KEY=CHAPUBK_TEST-your_key_here

# ── URLs ─────────────────────────────────────────────
BACKEND_URL=http://localhost:5002
CLIENT_URL=http://localhost:5173

# ── Platform Accounts ────────────────────────────────
PLATFORM_TELEBIRR=+251912345678
PLATFORM_TELEBIRR_NAME=Smart Garaging System
PLATFORM_CBE_ACCOUNT=1000123456789
PLATFORM_CBE_NAME=Smart Garaging System
PLATFORM_ABYSSINIA_ACCOUNT=2000987654321

# ── Email ────────────────────────────────────────────
EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password
